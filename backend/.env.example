PORT=5000
NODE_ENV=development

# Health checks: max wait (ms) for DB SELECT 1 and Horizon ledger probe (default 3000)
# HEALTH_CHECK_TIMEOUT_MS=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cbpa_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m

# Refresh tokens (session cookie max-age; default 30 days)
REFRESH_TOKEN_DAYS=30

# Stellar Network (use 'testnet' for development, 'mainnet' for production)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Optional fallback Horizon node — used automatically if the primary is unreachable (network errors only)
STELLAR_HORIZON_FALLBACK_URL=https://horizon-testnet.stellar.org

# Encryption key for private keys (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here_

# Frontend URL for CORS and email links (recommended; server warns if unset)
FRONTEND_URL=http://localhost:3000

# SMTP (email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@afripay.com

# KYC transaction threshold in USD equivalent (default: 100)
KYC_THRESHOLD_USD=100

# Approximate XLM/USD rate for threshold checks (replace with live feed in production)
XLM_USD_RATE=0.11
# USDC issuer address on Stellar
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Transaction amount limits
# Stellar minimum is 0.0000001 XLM (1 stroop)
MAX_TRANSACTION_AMOUNT=1000000
DAILY_SEND_LIMIT=10000
# Transaction limits
# Minimum amount per transaction (Stellar minimum = 0.0000001)
MIN_TRANSACTION_AMOUNT=0.0000001
# Maximum amount per single transaction
MAX_TRANSACTION_AMOUNT=100000
# Maximum total sent per user per calendar day (UTC)
DAILY_SEND_LIMIT=50000
# Redis (optional) — if not set, balance caching is disabled and live Horizon calls are used
# REDIS_URL=redis://localhost:6379

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@afripay.app
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Soroban Agent Escrow Contract
# Deploy with: CONTRACT=agent-escrow ./contracts/deploy.sh
AGENT_ESCROW_CONTRACT_ID=your_deployed_contract_id_here
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Platform fee in basis points (250 = 2.5%)
ESCROW_FEE_BPS=250

# Prometheus metrics endpoint bearer token (leave unset to disable auth in dev)
METRICS_TOKEN=change_me_to_a_strong_random_secret

# Referral program: fee discount credit per successful referral in basis points (50 = 0.5%)
REFERRAL_CREDIT_BPS=50
