PORT=5000
NODE_ENV=development

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Health checks: max wait (ms) for DB SELECT 1 and Horizon ledger probe (default 3000)
# HEALTH_CHECK_TIMEOUT_MS=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cbpa_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=15m

# Password policy
# Minimum password length enforced at registration (default: 8)
PASSWORD_MIN_LENGTH=8

# Refresh tokens (session cookie max-age; default 30 days)
REFRESH_TOKEN_DAYS=30

# Stellar Network (use 'testnet' for development, 'mainnet' for production)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# Optional fallback Horizon node — used automatically if the primary is unreachable (network errors only)
STELLAR_HORIZON_FALLBACK_URL=https://horizon-testnet.stellar.org

# Encryption key for private keys (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here_

# Frontend URL for CORS and email links (recommended; server warns if unset)
FRONTEND_URL=http://localhost:3000

# SMTP (email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@afripay.com

# Platform fee in basis points (default: 50 = 0.5%)
# fee = amount * FEE_BPS / 10000
FEE_BPS=50

# KYC transaction threshold in USD equivalent (default: 100)
# KYC and Limits
KYC_THRESHOLD_USD=100

# Fraud detection — both checks share the same rolling time window
# Rolling window in hours for velocity and daily-limit checks (default: 24)
DAILY_LIMIT_WINDOW_HOURS=24
# Max transactions allowed within the window before blocking (default: 5)
FRAUD_MAX_TX_PER_WINDOW=5
# Max USD-equivalent total a wallet can send within the window (default: 1000)
FRAUD_DAILY_LIMIT_USD=1000

# Approximate XLM/USD rate for threshold checks (replace with live feed in production)
DAILY_SEND_LIMIT=50000
PHONE_VERIFICATION_THRESHOLD_USD=100
XLM_USD_RATE=0.11

# SMS Configuration
# SMS_PROVIDER: 'twilio', 'africastalking', or leave empty for mock
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# USDC issuer address on Stellar
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Transaction amount limits
# Stellar minimum is 0.0000001 XLM (1 stroop)
MAX_TRANSACTION_AMOUNT=1000000
DAILY_SEND_LIMIT=10000

# AFRI Token Configuration
# Generate keypairs using: node -e "const StellarSdk = require('@stellar/stellar-sdk'); const pair = StellarSdk.Keypair.random(); console.log('Public:', pair.publicKey(), '\nSecret:', pair.secret());"
AFRI_ISSUER_PUBLIC=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AFRI_ISSUER_SECRET=encrypted_secret_key_here
AFRI_DISTRIBUTION_PUBLIC=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AFRI_DISTRIBUTION_SECRET=encrypted_secret_key_here
# Transaction limits
# Minimum amount per transaction (Stellar minimum = 0.0000001)
MIN_TRANSACTION_AMOUNT=0.0000001
# Maximum amount per single transaction
MAX_TRANSACTION_AMOUNT=100000
# Maximum total sent per user per calendar day (UTC)
DAILY_SEND_LIMIT=50000
# Redis (optional) — if not set, balance caching is disabled and live Horizon calls are used
# REDIS_URL=redis://localhost:6379

# Balance cache TTL in seconds (default: 30)
# Time-To-Live for cached wallet balance data. Lower values ensure fresher data but increase load on Horizon.
# Higher values reduce load but may show stale balances after recent transactions.
BALANCE_CACHE_TTL_SECONDS=30

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@afripay.app
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Admin IP Allowlist (comma-separated CIDR ranges, e.g. 10.0.0.0/8,203.0.113.5/32)
# If unset, admin routes are accessible from any IP (not recommended for production)
ADMIN_IP_ALLOWLIST=

# Payment Channels: unilateral close timeout in seconds (default 86400 = 24h)
CHANNEL_TIMEOUT_SECONDS=86400

# Soroban Agent Escrow Contract
# Deploy with: CONTRACT=agent-escrow ./contracts/deploy.sh
AGENT_ESCROW_CONTRACT_ID=your_deployed_contract_id_here
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Platform fee in basis points (250 = 2.5%)
ESCROW_FEE_BPS=250
# Max ms to wait for Soroban transaction confirmation before returning 504 (default: 30000)
SOROBAN_CONFIRMATION_TIMEOUT_MS=30000

# Prometheus metrics endpoint bearer token (leave unset to disable auth in dev)
METRICS_TOKEN=change_me_to_a_strong_random_secret

# Referral program: fee discount credit per successful referral in basis points (50 = 0.5%)
REFERRAL_CREDIT_BPS=50
# Soroban Loyalty Token Contract (SEP-41)
# Deploy with: CONTRACT=loyalty-token ./contracts/deploy.sh
LOYALTY_TOKEN_CONTRACT_ID=your_loyalty_token_contract_id_here
# Encrypted secret key of the mint-authority account (admin that calls mint)
LOYALTY_ADMIN_KEY=iv_hex:encrypted_hex
# Soroban Dispute Resolution Contract
# Deploy with: CONTRACT=dispute-resolution ./contracts/deploy.sh
DISPUTE_RESOLUTION_CONTRACT_ID=your_dispute_contract_id_here
# Encrypted secret key of the platform arbitrator account (same format as wallet keys)
ARBITRATOR_ENCRYPTED_KEY=iv_hex:encrypted_hex
# Geo-restriction — comma-separated ISO 3166-1 alpha-2 country codes
# Requests from these countries receive HTTP 451 (Unavailable For Legal Reasons)
BLOCKED_COUNTRIES=KP,IR,CU,RU,SY
# Soroban KYC Attestation Contract
# Deploy with: CONTRACT=kyc-attestation ./contracts/deploy.sh
KYC_ATTESTATION_CONTRACT_ID=your_deployed_contract_id_here
# AES-256 encrypted secret key for the admin Stellar wallet (same format as user keys)
ADMIN_ENCRYPTED_SECRET_KEY=your_encrypted_admin_secret_key_here

# Soroban Fee Distributor Contract
# Deploy with: CONTRACT=fee-distributor ./contracts/deploy.sh
FEE_DISTRIBUTOR_CONTRACT_ID=your_deployed_contract_id_here
# AES-256 encrypted secret key for the service wallet that holds USDC for fee deposits
SERVICE_ENCRYPTED_SECRET_KEY=your_encrypted_service_secret_key_here
# Anchor URL allowlist (comma-separated hostnames for SEP-6/SEP-24 anchor responses)
# URLs returned by the anchor that do not match one of these hostnames are rejected with 502.
# Example: ANCHOR_DOMAIN=anchor.example.com,testanchor.stellar.org
ANCHOR_DOMAIN=testanchor.stellar.org

# Platform fee in basis points applied to USDC payments (250 = 2.5%)
PLATFORM_FEE_BPS=250
